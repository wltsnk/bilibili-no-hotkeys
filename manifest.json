{
  "manifest_version": 3,
  "name": "B站快捷键自定义",
  "version": "2.0.1",
  "description": "在B站自由选择保留哪些键盘快捷键，其余全部禁用。",
  "permissions": ["storage"],
  "host_permissions": ["*://*.bilibili.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "options_page": "options.html"
}